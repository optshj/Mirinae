{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": ["src/renderer/env.d.ts", "src/renderer/**/*", "src/renderer/**/*.tsx", "src/preload/*.d.ts", "src/renderer/shared", "src/renderer/global.d.ts"],
  "compilerOptions": {
    "moduleResolution": "bundler",
    "composite": true,
    "jsx": "react-jsx",
    "paths": {
      "@/*": ["./src/renderer/*"]
    }
  }
}
